{
  "version": 2,
  "installCommand": "cd ecommerce-frontend-web && npm install",
  "buildCommand": "cd ecommerce-frontend-web && npm run build",
  "outputDirectory": "ecommerce-frontend-web/build",
  "redirects": [
    {
      "source": "/",
      "destination": "https://nexora-commerce-surya.kssuryaprakash2.chatgpt.site/",
      "permanent": false
    },
    {
      "source": "/:path*",
      "destination": "https://nexora-commerce-surya.kssuryaprakash2.chatgpt.site/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
